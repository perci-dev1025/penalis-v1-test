PORT=3003
DATABASE_URL=
JWT_SECRET=<generate-a-long-random-secret>
CORS_ORIGIN=http://localhost:5173
RAG_SIMILARITY_THRESHOLD_DEFAULT=0.1
RAG_SIMILARITY_THRESHOLD_CONSULTA=0.1
RAG_SIMILARITY_THRESHOLD_AUDIENCIA=0.2
RAG_SIMILARITY_THRESHOLD_DEBATE=0.1
RAG_SIMILARITY_THRESHOLD_FORMATOS=0.1
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_API_KEY=<your-openai-api-key>
# Optional: model for PROMPT MAESTRO (Hearing Mode). Default: gpt-4o-mini
RAG_MAESTRO_MODEL=gpt-4o-mini
# Optional: model for PROMPT MASTER SUPERIOR (Debate Mode). Default: same as RAG_MAESTRO_MODEL
RAG_DEBATE_MASTER_MODEL=gpt-4o-mini
